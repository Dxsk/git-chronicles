---
layout: layouts/base.njk
extra_css: /assets/css/print.css
---

<article class="cheatsheet">
  <div class="cheatsheet-header">
    <h1>{{ title }}</h1>
    <button class="print-btn" onclick="window.print()">
      {% if lang == "fr" %}Imprimer{% else %}Print{% endif %}
    </button>
  </div>

  {{ content | safe }}
</article>
