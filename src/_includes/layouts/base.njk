<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {% if lang == "fr" %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif %}</title>
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" media="print" onload="this.media='all'">
  {% if extra_css %}<link rel="stylesheet" href="{{ extra_css }}" media="print">{% endif %}
  {% if quest_id %}
  <link rel="alternate" hreflang="fr" href="{{ site.url }}/fr/quetes/{{ quest_slug_fr }}/">
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/quests/{{ quest_slug_en }}/">
  {% elif cheatsheet_slug_fr %}
  <link rel="alternate" hreflang="fr" href="{{ site.url }}/fr/cheatsheets/{{ cheatsheet_slug_fr }}/">
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/cheatsheets/{{ cheatsheet_slug_en }}/">
  {% else %}
  <link rel="alternate" hreflang="fr" href="{{ site.url }}/fr/">
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/">
  {% endif %}
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}/fr/">
  <link rel="prefetch" href="/ai.txt">
  <link rel="prefetch" href="/llms.txt">
  <link rel="author" href="/humans.txt">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
  <meta name="theme-color" content="#8b4513">
  {% set meta_desc_fr = subtitle | default('Apprendre Git gratuitement avec un cours interactif et gamifié. 29 exercices pratiques dans un univers heroic fantasy. Tutoriel Git complet du débutant au CI/CD. Bilingue FR/EN, 100% gratuit et open source.') %}
  {% set meta_desc_en = subtitle | default('Learn Git for free with an interactive, gamified course. 29 hands-on exercises in a fantasy RPG universe. Complete Git tutorial from beginner to CI/CD. Bilingual FR/EN, 100% free and open source.') %}
  {% set meta_desc = meta_desc_fr if lang == "fr" else meta_desc_en %}
  {% set meta_title = title + " - " + ("Les Chroniques du Versionneur | Cours Git Gratuit" if lang == "fr" else "The Git Chronicles | Free Git Course") %}
  {% set site_name = "Les Chroniques du Versionneur" if lang == "fr" else "The Git Chronicles" %}
  <meta name="description" content="{{ meta_desc }}">
  {% if quest_id %}
  <meta name="keywords" content="Git, {{ subtitle }}, {% if lang == 'fr' %}apprendre Git, tutoriel Git, cours Git gratuit, exercices Git, formation Git, Git pour débutant, gestion de version{% else %}learn Git, Git tutorial, free Git course, Git exercises, Git training, Git for beginners, version control{% endif %}">
  {% elif cheatsheet_slug_fr %}
  <meta name="keywords" content="Git, {{ title }}, {% if lang == 'fr' %}aide-mémoire Git, cheatsheet Git, commandes Git, référence rapide Git{% else %}Git cheatsheet, Git commands, Git quick reference, Git cheat sheet{% endif %}">
  {% elif codex_type %}
  <meta name="keywords" content="Git, {{ title }}, {% if lang == 'fr' %}apprendre Git, univers, lore, gamifié{% else %}learn Git, universe, lore, gamified{% endif %}">
  {% else %}
  <meta name="keywords" content="Git, {% if lang == 'fr' %}apprendre Git, cours Git gratuit, tutoriel Git, exercices Git, formation Git débutant, gestion de version, GitHub, GitLab, CI/CD, heroic fantasy, gamifié, interactif{% else %}learn Git, free Git course, Git tutorial, Git exercises, Git training beginner, version control, GitHub, GitLab, CI/CD, heroic fantasy, gamified, interactive{% endif %}">
  {% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <!-- Open Graph -->
  <meta property="og:type" content="{% if quest_id %}article{% else %}website{% endif %}">
  <meta property="og:locale" content="{{ 'fr_FR' if lang == 'fr' else 'en_US' }}">
  <meta property="og:locale:alternate" content="{{ 'en_US' if lang == 'fr' else 'fr_FR' }}">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:title" content="{{ meta_title }}">
  <meta property="og:description" content="{{ meta_desc }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/img/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ site_name }}">
  {% if quest_id %}
  <meta property="article:section" content="{% if lang == 'fr' %}Quete{% else %}Quest{% endif %} {{ quest_number }}">
  <meta property="article:tag" content="Git">
  <meta property="article:tag" content="{{ subtitle }}">
  <meta property="article:published_time" content="{{ page.date.toISOString() }}">
  {% endif %}
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ meta_title }}">
  <meta name="twitter:description" content="{{ meta_desc }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/img/og-image.png">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "{% if lang == 'fr' %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif %}",
    "description": "{% if lang == 'fr' %}Apprendre Git gratuitement avec un cours interactif et gamifié. 29 exercices pratiques dans un univers heroic fantasy, de git init au CI/CD. Tutoriel Git complet, bilingue FR/EN, 100% gratuit et open source.{% else %}Learn Git for free with an interactive, gamified course. 29 hands-on exercises in a fantasy RPG universe, from git init to CI/CD. Complete Git tutorial, bilingual FR/EN, 100% free and open source.{% endif %}",
    "url": "{{ site.url }}/{{ lang }}/",
    "provider": {
      "@type": "Person",
      "name": "Dxsk",
      "url": "https://github.com/Dxsk"
    },
    "inLanguage": ["fr", "en"],
    "isAccessibleForFree": true,
    "license": "https://opensource.org/licenses/MIT",
    "teaches": ["Git", "Version Control", "CI/CD", "GitHub", "GitLab", "Git LFS", "Radicle"],
    "numberOfCredits": 29,
    "hasCourseInstance": {
      "@type": "CourseInstance",
      "courseMode": "online",
      "courseWorkload": "29 quests (23 main + 6 bonus)"
    }
  }
  </script>
  {% if quest_id %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LearningResource",
    "name": "{{ title }}",
    "description": "{{ subtitle }}",
    "inLanguage": "{{ lang }}",
    "url": "{{ site.url }}{{ page.url }}",
    "isPartOf": {
      "@type": "Course",
      "name": "{% if lang == 'fr' %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif %}",
      "url": "{{ site.url }}/{{ lang }}/"
    },
    "learningResourceType": "quest",
    "position": "{{ quest_number }}",
    "teaches": "{{ subtitle }}",
    "isAccessibleForFree": true,
    "author": { "@type": "Person", "name": "Dxsk" }
  }
  </script>
  {% elif cheatsheet_slug_fr %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "name": "{{ title }}",
    "headline": "{{ title }}",
    "inLanguage": "{{ lang }}",
    "url": "{{ site.url }}{{ page.url }}",
    "isPartOf": {
      "@type": "Course",
      "name": "{% if lang == 'fr' %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif %}",
      "url": "{{ site.url }}/{{ lang }}/"
    },
    "isAccessibleForFree": true,
    "author": { "@type": "Person", "name": "Dxsk" }
  }
  </script>
  {% elif codex_type %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "name": "{{ title }}",
    "headline": "{{ title }}",
    "description": "{{ subtitle | default(title) }}",
    "inLanguage": "{{ lang }}",
    "url": "{{ site.url }}{{ page.url }}",
    "articleSection": "Codex",
    "isAccessibleForFree": true,
    "author": { "@type": "Person", "name": "Dxsk" }
  }
  </script>
  {% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "{% if lang == 'fr' %}Accueil{% else %}Home{% endif %}",
        "item": "{{ site.url }}/{{ lang }}/"
      }
      {% if quest_id %},{
        "@type": "ListItem",
        "position": 2,
        "name": "{% if lang == 'fr' %}Quetes{% else %}Quests{% endif %}"
      },{
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}"
      }
      {% elif cheatsheet_slug_fr %},{
        "@type": "ListItem",
        "position": 2,
        "name": "Cheatsheets"
      },{
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}"
      }
      {% elif codex_type %},{
        "@type": "ListItem",
        "position": 2,
        "name": "Codex"
      },{
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}"
      }
      {% endif %}
    ]
  }
  </script>
</head>
<body>
  <div class="wip-banner">
    {% if lang == "fr" %}
      🚧 Ce site est en cours de construction. Le contenu peut évoluer.
    {% else %}
      🚧 This site is a work in progress. Content may change.
    {% endif %}
  </div>
  <header class="site-header">
    <a href="/{{ lang }}/" class="logo">
      {%- if lang == "fr" %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif -%}
    </a>
    <div class="header-actions">
      <a href="https://github.com/Dxsk/git-chronicles" class="header-github" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <div class="lang-switch">
        {% if lang == "fr" %}
          <span class="lang-active">FR</span>
          {% if quest_id %}
            <a href="/en/quests/{{ quest_slug_en }}/" hreflang="en">EN</a>
          {% elif cheatsheet_slug_en %}
            <a href="/en/cheatsheets/{{ cheatsheet_slug_en }}/" hreflang="en">EN</a>
          {% else %}
            <a href="/en/" hreflang="en">EN</a>
          {% endif %}
        {% else %}
          {% if quest_id %}
            <a href="/fr/quetes/{{ quest_slug_fr }}/" hreflang="fr">FR</a>
          {% elif cheatsheet_slug_fr %}
            <a href="/fr/cheatsheets/{{ cheatsheet_slug_fr }}/" hreflang="fr">FR</a>
          {% else %}
            <a href="/fr/" hreflang="fr">FR</a>
          {% endif %}
          <span class="lang-active">EN</span>
        {% endif %}
      </div>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">&#9776;</button>
    </div>
  </header>

  <div class="page-wrapper">
    <aside class="sidebar-nav" id="nav-container"></aside>
    <main class="main-content" data-pagefind-body>
      {{ content | safe }}
      <nav class="nav-footer" id="nav-footer"></nav>
    </main>
    <aside class="toc-sidebar" id="toc-sidebar">
      <nav class="toc-nav" aria-label="{% if lang == 'fr' %}Sommaire de la page{% else %}On this page{% endif %}">
        <div class="toc-title">{% if lang == "fr" %}Sur cette page{% else %}On this page{% endif %}</div>
        <ul class="toc-list" id="toc-list"></ul>
      </nav>
    </aside>
  </div>

  <footer class="site-footer">
    <div class="footer-content">
      <p>
        {% if lang == "fr" %}
          <a href="https://github.com/Dxsk/git-chronicles">Les Chroniques du Versionneur</a>, un projet libre et open source par <a href="https://github.com/Dxsk" target="_blank" rel="noopener">🇫🇷 Dxsk</a>.
        {% else %}
          <a href="https://github.com/Dxsk/git-chronicles">The Git Chronicles</a>, a free and open source project by <a href="https://github.com/Dxsk" target="_blank" rel="noopener">🇫🇷 Dxsk</a>.
        {% endif %}
      </p>
      <p class="footer-thanks">
        {% if lang == "fr" %}
          Merci à <a href="https://github.com/Andralax" target="_blank" rel="noopener">@Andralax</a> pour ses idées et sa relecture.
        {% else %}
          Thanks to <a href="https://github.com/Andralax" target="_blank" rel="noopener">@Andralax</a> for ideas and proofreading.
        {% endif %}
      </p>
      <p class="footer-license">
        {% if lang == "fr" %}
          Code sous licence <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT</a> · Contenu sous licence <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC BY-SA 4.0</a>
        {% else %}
          Code licensed under <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT</a> · Content licensed under <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC BY-SA 4.0</a>
        {% endif %}
      </p>
    </div>
  </footer>

  <script>
    window.__lang = "{{ lang }}";
  </script>
  <script src="/assets/js/nav.js" defer></script>
  <script src="/assets/js/highlight.js" defer></script>
  <script src="/assets/js/toc.js" defer></script>

  <!-- Search FAB + modal -->
  <button class="search-fab" id="search-fab" aria-label="{% if lang == 'fr' %}Rechercher{% else %}Search{% endif %}">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
  </button>
  <div class="search-overlay" id="search-overlay">
    <div class="search-modal" role="dialog" aria-modal="true" aria-label="{% if lang == 'fr' %}Recherche{% else %}Search{% endif %}">
      <div class="search-modal-header">
        <span class="search-modal-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          {% if lang == 'fr' %}Recherche{% else %}Search{% endif %}
          <kbd class="search-kbd">Ctrl+K</kbd>
        </span>
        <button class="search-close" id="search-close" aria-label="{% if lang == 'fr' %}Fermer{% else %}Close{% endif %}">&times;</button>
      </div>
      <div id="search-container"></div>
    </div>
  </div>

  <script src="/pagefind/pagefind-ui.js" defer></script>
  <script>
    (function() {
      var fab = document.getElementById("search-fab");
      var overlay = document.getElementById("search-overlay");
      var closeBtn = document.getElementById("search-close");
      var initialized = false;

      function openSearch() {
        if (!initialized) {
          if (typeof PagefindUI === "undefined") {
            document.getElementById("search-container").innerHTML = "<p style='padding:1rem;color:#8b4513;'>{% if lang == 'fr' %}Recherche indisponible en mode développement. Lancez <code>npm run build</code> pour générer l'index.{% else %}Search unavailable in dev mode. Run <code>npm run build</code> to generate the index.{% endif %}</p>";
            initialized = true;
            overlay.classList.add("active");
            return;
          }
          new PagefindUI({
            element: "#search-container",
            showSubResults: true,
            showImages: false,
            translations: window.__lang === "fr" ? {
              placeholder: "Rechercher dans les chroniques...",
              zero_results: "Aucun résultat pour \u00ab [SEARCH_TERM] \u00bb",
              many_results: "[COUNT] résultats pour \u00ab [SEARCH_TERM] \u00bb",
              one_result: "1 résultat pour \u00ab [SEARCH_TERM] \u00bb"
            } : {
              placeholder: "Search the chronicles..."
            }
          });
          initialized = true;
        }
        overlay.classList.add("active");
        document.body.style.overflow = "hidden";
        setTimeout(function() {
          var input = overlay.querySelector(".pagefind-ui__search-input");
          if (input) input.focus();
        }, 100);
      }

      function closeSearch() {
        overlay.classList.remove("active");
        document.body.style.overflow = "";
      }

      fab.addEventListener("click", openSearch);
      closeBtn.addEventListener("click", closeSearch);
      overlay.addEventListener("click", function(e) {
        if (e.target === overlay) closeSearch();
      });
      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") closeSearch();
        if ((e.ctrlKey || e.metaKey) && e.key === "k") { e.preventDefault(); openSearch(); }
      });
    })();
  </script>
</body>
</html>
